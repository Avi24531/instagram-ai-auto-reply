      "parameters": {
        "jsCode": "const rawOutput = $('AI Agent').item.json.output;\n\n// Extract just the text value from the nested JSON\nlet messageText;\ntry {\n  const parsed = JSON.parse(rawOutput);\n  messageText = parsed.message?.text || rawOutput;\n} catch(e) {\n  messageText = rawOutput;\n}\n\nreturn [{\n  json: {\n    sender_id: $('Webhook').item.json.body.entry[0].messaging[0].sender.id,\n    message_text: messageText.replace(/\\n/g, ' ').trim()\n  }\n}];"
